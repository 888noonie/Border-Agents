# Copy this file to .env and fill in your Hermes provider details.
#
# OpenAI-compatible providers:
# - xAI / Grok:      HERMES_API_BASE=https://api.x.ai/v1
# - OpenRouter:     HERMES_API_BASE=https://openrouter.ai/api/v1
# - LM Studio:      HERMES_API_BASE=http://127.0.0.1:1234/v1
# - Ollama OpenAI:  HERMES_API_BASE=http://127.0.0.1:11434/v1

HERMES_PROVIDER=xai
HERMES_API_BASE=https://api.x.ai/v1
HERMES_API_KEY=
HERMES_MODEL=

# Optional: override the gateway's Hermes system prompt.
HERMES_SYSTEM_PROMPT=You are Hermes, a concise desktop companion speaking through the Border Agents buddy gateway. Be direct, useful, and clear.
