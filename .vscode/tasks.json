{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "BB start",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-start.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "Daily driver: real soul (launchers + gate) + native body. Logs → .bb-logs/"
    },
    {
      "label": "BB start full",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-start-all.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BB_START_SOUL": "governance",
          "BB_TARGET": "${input:frameTarget}"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "Full stack: soul + browser preview (:1420) + frame driver + native body"
    },
    {
      "label": "BB start (wizard)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-start-all.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BB_START_SOUL": "wizard",
          "BB_TARGET": "${input:frameTarget}"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "Legacy: wizard gateway stub + browser + frame + body. Prefer BB wizard host for Build C."
    },
    {
      "label": "BB wizard host (onboarding)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-wizard-host.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "Build C smoke: real soul (BB_SOUL=wizard) + native host body (BB_BUDDY=host). No browser/frame."
    },
    {
      "label": "BB forge + soul + frame",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-forge-stack.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "BB_TARGET": "${input:frameTarget}" }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "Commandeer stack: governance soul + COSMIC frame driver + forge body (BB_BUDDY=forge)"
    },
    {
      "label": "BB spawn",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-spawn.sh", "${input:spawnBuddy}"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "Add another buddy body (soul must already be running — run BB start first)"
    },
    {
      "label": "BB stop",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-stop.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Stop soul, gateway, frame driver, all bodies, and Vite preview"
    },

    {
      "label": "BB soul",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-soul.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": [],
      "detail": "Soul only — action gate + launchers on ws://127.0.0.1:17387"
    },
    {
      "label": "BB body",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-body.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "Native body only — stops any existing body first, then rebuilds"
    },
    {
      "label": "BB gateway (chat)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-gateway.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": [],
      "detail": "Escape hatch: provider chat + stub gate (until unified soul). Same port as soul — stop one before starting the other"
    },
    {
      "label": "BB browser preview",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-browser.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "group": "bb"
      },
      "problemMatcher": [],
      "detail": "Vite harness at http://127.0.0.1:1420 — needs soul or gateway on :17387"
    },
    {
      "label": "BB frame driver",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-frame.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "BB_TARGET": "${input:frameTarget}" }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true,
        "group": "bb"
      },
      "problemMatcher": ["$rustc"],
      "detail": "COSMIC window pin — emits target_* cues (needs soul or gateway relaying)"
    },

    {
      "label": "Test (vitest)",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": [],
      "detail": "TypeScript suite (vitest run)"
    },
    {
      "label": "Test (rust body)",
      "type": "shell",
      "command": "cargo test --manifest-path desktop-body/Cargo.toml",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": ["$rustc"],
      "detail": "Native body cargo tests"
    },
    {
      "label": "Gen fixtures",
      "type": "shell",
      "command": "npm run gen:fixtures",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Regenerate fixtures/presence-v0.json from TS factories"
    },

    {
      "label": "Report",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-report.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": false },
      "problemMatcher": [],
      "detail": "After a crash: .bb-logs/bb-events.log + process status"
    },
    {
      "label": "Clean cache",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-clean.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Remove dist, Vite cache, Rust target artifacts"
    }
  ],
  "inputs": [
    {
      "id": "frameTarget",
      "type": "promptString",
      "description": "Window to track (title / app_id substring)",
      "default": "firefox"
    },
    {
      "id": "spawnBuddy",
      "type": "promptString",
      "description": "Buddy to spawn (wire id: crab, hermes, owl, forge, …)",
      "default": "crab"
    }
  ]
}
