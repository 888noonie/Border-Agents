{
  "version": "2.0.0",
  // Run tasks track the live native stack: soul (or gateway/wizard) + frame driver +
  // desktop body. Only one process may bind ws://127.0.0.1:17387 — Start ALL picks
  // the soul mode; use Start ALL (wizard) for onboarding.
  "tasks": [
    // ── RUN ─────────────────────────────────────────────────────────────────
    {
      "label": "Start ALL",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-start-all.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BB_START_SOUL": "governance",
          "BB_TARGET": "${input:frameTarget}"
        }
      },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": ["$rustc"],
      "detail": "Full stack: real soul (action gate) + COSMIC frame driver + native body. Logs to .bb-logs/"
    },
    {
      "label": "Start ALL (wizard)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-start-all.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BB_START_SOUL": "wizard",
          "BB_TARGET": "${input:frameTarget}"
        }
      },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": ["$rustc"],
      "detail": "Onboarding stack: wizard gateway soul + frame driver + native body (no real action gate — use Start ALL for governance)"
    },
    {
      "label": "Start (gateway + body)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-start.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": [],
      "detail": "Light stack: dev gateway + native body only (no frame driver, no real soul gate)"
    },
    {
      "label": "Soul",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-soul.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": [],
      "detail": "Real soul only (npm run soul:dev) — runs the actual action gate on ws://127.0.0.1:17387/border-buddies"
    },
    {
      "label": "Gateway",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-gateway.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": [],
      "detail": "Dev gateway only (echo/provider soul) on ws://127.0.0.1:17387/border-buddies — relays frame cues; action gate is stubbed"
    },
    {
      "label": "Gateway (wizard soul)",
      "type": "shell",
      "command": "npm run gateway:wizard",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": [],
      "detail": "Gateway with BB_SOUL=wizard — onboarding persona; on-body text is NOT routed to a provider"
    },
    {
      "label": "Body",
      "type": "shell",
      "command": "bash scripts/bb-body.sh",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": ["$rustc"],
      "detail": "Build + run the native desktop presence body — single-instance (stops any running body first)"
    },
    {
      "label": "Frame driver",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-frame.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "BB_TARGET": "${input:frameTarget}" }
      },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": ["$rustc"],
      "detail": "Track a native COSMIC window and emit target_* presence cues (relayed by soul or gateway)"
    },
    {
      "label": "UI preview (browser)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "group": "stack" },
      "problemMatcher": [],
      "detail": "Buddy UI in a plain browser tab at 127.0.0.1:1420 — fast visual iteration, no Wayland overlay. A dev harness, not a buddy."
    },

    // ── STOP / RESTART ──────────────────────────────────────────────────────
    {
      "label": "Stop (all)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-stop.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Stop soul, gateway, frame driver, desktop body, and Vite dev server"
    },
    {
      "label": "Stop body",
      "type": "shell",
      "command": "pkill -x bb-desktop-body || echo 'no desktop body running'",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Stop just the native desktop body"
    },
    {
      "label": "Stop soul",
      "type": "shell",
      "command": "bash -c 'pkill -f \"tsx scripts/soul-server\" 2>/dev/null; ss -ltnp 2>/dev/null | awk \"/:17387 /\" | sed -n \"s/.*pid=\\([0-9][0-9]*\\).*/\\1/p\" | xargs -r kill 2>/dev/null; echo done'",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Stop the real soul server (and anything else on port 17387)"
    },
    {
      "label": "Stop frame driver",
      "type": "shell",
      "command": "pkill -x bb-frame-driver || echo 'no frame driver running'",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Stop just the COSMIC frame-geometry driver"
    },
    {
      "label": "Restart body",
      "type": "shell",
      "command": "bash scripts/bb-body.sh",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true, "group": "stack" },
      "problemMatcher": ["$rustc"],
      "detail": "Stop, then rebuild + run the latest desktop body (same single-instance launcher as Body)"
    },

    // ── TEST ────────────────────────────────────────────────────────────────
    {
      "label": "Test (vitest)",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": [],
      "detail": "Run the TypeScript suite (vitest run)"
    },
    {
      "label": "Test (rust body)",
      "type": "shell",
      "command": "cargo test --manifest-path desktop-body/Cargo.toml",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": ["$rustc"],
      "detail": "Run the native body's cargo test suite (presence parser parity, etc.)"
    },
    {
      "label": "Gen fixtures",
      "type": "shell",
      "command": "npm run gen:fixtures",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Regenerate fixtures/presence-v0.json from the canonical TS factories"
    },

    // ── DIAGNOSTICS ─────────────────────────────────────────────────────────
    {
      "label": "Report",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-report.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": false },
      "problemMatcher": [],
      "detail": "Print .bb-logs/bb-events.log and process status after a crash"
    },
    {
      "label": "Clean cache",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-clean.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": [],
      "detail": "Remove dist, Vite cache, and Rust target build artifacts"
    }
  ],
  "inputs": [
    {
      "id": "frameTarget",
      "type": "promptString",
      "description": "Window to track (title / app_id substring)",
      "default": "firefox"
    }
  ]
}