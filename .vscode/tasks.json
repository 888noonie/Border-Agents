{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "BB start",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-start.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": [],
      "detail": "Start gateway + desktop; logs to .bb-logs/bb-latest.log"
    },
    {
      "label": "BB gateway",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-gateway.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": [],
      "detail": "Gateway only; logs to .bb-logs/bb-latest.log"
    },
    {
      "label": "BB stop",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-stop.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Stop desktop overlay, Vite dev server, and gateway"
    },
    {
      "label": "BB report",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-report.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": [],
      "detail": "Print .bb-logs/bb-events.log and process status after a crash"
    },
    {
      "label": "BB clean cache",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/bb-clean.sh"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Remove dist, Vite cache, and Rust target build artifacts"
    },
    {
      "label": "BB browser preview",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Browser-only Vite preview (no Tauri overlay)"
    },
    {
      "label": "BB body start",
      "type": "shell",
      "command": "cargo run --release",
      "options": {
        "cwd": "${workspaceFolder}/desktop-body"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": ["$rustc"],
      "detail": "Build + run the native desktop presence body (animated buddy on the wlr overlay layer)"
    },
    {
      "label": "BB body stop",
      "type": "shell",
      "command": "pkill -x bb-desktop-body || echo 'no desktop body running'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Stop the desktop presence body"
    },
    {
      "label": "BB body restart",
      "type": "shell",
      "command": "pkill -x bb-desktop-body; sleep 0.5; cargo run --release",
      "options": {
        "cwd": "${workspaceFolder}/desktop-body"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": ["$rustc"],
      "detail": "Stop, then rebuild + run the latest desktop presence body"
    }
  ]
}
