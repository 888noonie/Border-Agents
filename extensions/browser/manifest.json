{
  "manifest_version": 3,
  "name": "Border Buddies",
  "version": "0.1.0",
  "description": "Cute draggable AI companions that peek from the browser edge.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>", "ws://127.0.0.1/*", "ws://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Border Buddies",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["presence.js", "profiles.js", "hermes.js", "content.js"],
      "css": ["buddies.css"],
      "run_at": "document_idle"
    }
  ]
}
